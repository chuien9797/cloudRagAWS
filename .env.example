# =========================
# API & Environment
# =========================
ENV=development
DEBUG=True

# =========================
# Security
# =========================
API_KEY=replace_with_a_random_64_hex_key
FRONTEND_API_KEY=
AUTH_SECRET=replace_with_a_random_64_hex_key
AUTH_ADMIN_EMAIL=admin@cloudrag.local
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_NAME=CloudRAG Admin
AUTH_TOKEN_TTL_HOURS=12

# =========================
# Ollama
# =========================
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=qwen2:1.5b
OLLAMA_KEEP_ALIVE=45m
OLLAMA_NUM_THREAD=2
OLLAMA_NUM_CTX=3072

# =========================
# Ask performance
# =========================
ASK_TOP_K=5
ASK_MAX_QUERY_VARIANTS=3
ASK_MAX_CONTEXT_WORDS=650
ASK_FACTUAL_NUM_PREDICT=120
ASK_ANALYTICAL_NUM_PREDICT=320
ASK_GROUND_CITATIONS=true

# =========================
# Frontend
# =========================
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8000
FRONTEND_API_BASE_URL=http://localhost:8000

# =========================
# Chroma Vector DB
# =========================
CHROMA_DIR=./chroma_db
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_API_KEY=

# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# =========================
# Redis (Cache)
# =========================
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
